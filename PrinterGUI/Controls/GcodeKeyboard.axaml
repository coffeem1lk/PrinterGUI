<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PrinterGUI.Controls.GcodeKeyboard">
  
    <UserControl.Styles>
        <Style Selector="Button">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>
    </UserControl.Styles>

    <Border Background="#F5F5F5" Padding="8" CornerRadius="4" BorderBrush="#D0D0D0" BorderThickness="1">
        <Grid ColumnDefinitions="Auto, 32, Auto" HorizontalAlignment="Center">
            
            <StackPanel Grid.Column="0" Spacing="8" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <Button Content="Q" Click="Character_Click" Width="48" Height="48" FontSize="18"/>
                    <Button Content="W" Click="Character_Click" Width="48" Height="48" FontSize="18"/>
                    <Button Content="E" Click="Character_Click" Width="48" Height="48" FontSize="18"/>
                    <Button Content="R" Click="Character_Click" Width="48" Height="48" FontSize="18"/>
                    <Button Content="T" Click="Character_Click" Width="48" Height="48" FontSize="18"/>
                    <Button Content="Y" Click="Character_Click" Width="48" Height="48" FontSize="18"/>
                    <Button Content="U" Click="Character_Click" Width="48" Height="48" FontSize="18"/>
                    <Button Content="I" Click="Character_Click" Width="48" Height="48" FontSize="18"/>
                    <Button Content="O" Click="Character_Click" Width="48" Height="48" FontSize="18"/>
                    <Button Content="P" Click="Character_Click" Width="48" Height="48" FontSize="18"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <Button Content="A" Click="Character_Click" Width="48" Height="48" FontSize="18"/>
                    <Button Content="S" Click="Character_Click" Width="48" Height="48" FontSize="18"/>
                    <Button Content="D" Click="Character_Click" Width="48" Height="48" FontSize="18"/>
                    <Button Content="F" Click="Character_Click" Width="48" Height="48" FontSize="18"/>
                    <Button Content="G" Click="Character_Click" Width="48" Height="48" FontSize="18"/>
                    <Button Content="H" Click="Character_Click" Width="48" Height="48" FontSize="18"/>
                    <Button Content="J" Click="Character_Click" Width="48" Height="48" FontSize="18"/>
                    <Button Content="K" Click="Character_Click" Width="48" Height="48" FontSize="18"/>
                    <Button Content="L" Click="Character_Click" Width="48" Height="48" FontSize="18"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <Button Content="Z" Click="Character_Click" Width="48" Height="48" FontSize="18"/>
                    <Button Content="X" Click="Character_Click" Width="48" Height="48" FontSize="18"/>
                    <Button Content="C" Click="Character_Click" Width="48" Height="48" FontSize="18"/>
                    <Button Content="V" Click="Character_Click" Width="48" Height="48" FontSize="18"/>
                    <Button Content="B" Click="Character_Click" Width="48" Height="48" FontSize="18"/>
                    <Button Content="N" Click="Character_Click" Width="48" Height="48" FontSize="18"/>
                    <Button Content="M" Click="Character_Click" Width="48" Height="48" FontSize="18"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <Button Content="Space" Click="Space_Click" Width="300" Height="48" FontSize="18"/>
                </StackPanel>
            </StackPanel>
            
            <Grid Grid.Column="2" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,*,*" ColumnSpacing="8" RowSpacing="8" VerticalAlignment="Center">
                <Button Grid.Row="0" Grid.Column="0" Content="1" Click="Number_Click" Height="48" Width="48" FontSize="18"/>
                <Button Grid.Row="0" Grid.Column="1" Content="2" Click="Number_Click" Height="48" Width="48" FontSize="18"/>
                <Button Grid.Row="0" Grid.Column="2" Content="3" Click="Number_Click" Height="48" Width="48" FontSize="18"/>
                
                <Button Grid.Row="1" Grid.Column="0" Content="4" Click="Number_Click" Height="48" Width="48" FontSize="18"/>
                <Button Grid.Row="1" Grid.Column="1" Content="5" Click="Number_Click" Height="48" Width="48" FontSize="18"/>
                <Button Grid.Row="1" Grid.Column="2" Content="6" Click="Number_Click" Height="48" Width="48" FontSize="18"/>
                
                <Button Grid.Row="2" Grid.Column="0" Content="7" Click="Number_Click" Height="48" Width="48" FontSize="18"/>
                <Button Grid.Row="2" Grid.Column="1" Content="8" Click="Number_Click" Height="48" Width="48" FontSize="18"/>
                <Button Grid.Row="2" Grid.Column="2" Content="9" Click="Number_Click" Height="48" Width="48" FontSize="18"/>
                
                <Button Grid.Row="3" Grid.Column="0" Content="-" Click="Character_Click" Height="48" Width="48" FontSize="18"/>
                <Button Grid.Row="3" Grid.Column="1" Content="0" Click="Number_Click" Height="48" Width="48" FontSize="18"/>
                <Button Grid.Row="3" Grid.Column="2" Content="." Click="Character_Click" Height="48" Width="48" FontSize="18"/>

                <Button Grid.Row="4" Grid.Column="0" Content="Del" Click="Del_Click" Height="48" Width="48" FontSize="18" Background="#E24A4A" Foreground="White"/>
                <Button Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Content="⏎ Enter" Click="Enter_Click" Height="48" FontSize="18" Background="#4A90E2" Foreground="White"/>
            </Grid>

        </Grid>
    </Border>
</UserControl>