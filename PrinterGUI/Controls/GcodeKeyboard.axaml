<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PrinterGUI.Controls.GcodeKeyboard">
  
    <UserControl.Styles>
        <!-- Prevent keyboard keys from stealing focus so the TextBox keeps it -->
        <Style Selector="Button">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="#E0E0E0"/> <!-- Slightly darker light grey for keys -->
            <Setter Property="Foreground" Value="Black"/>   <!-- Black text for keys -->
        </Style>
        
        <!-- Maintain special styles for specific buttons by targeting their classes if needed, 
             or letting inline background properties override this base style -->
    </UserControl.Styles>

    <!-- Main background color changed to a very light grey -->
    <Border Background="#F5F5F5" Padding="6" CornerRadius="4" BorderBrush="#D0D0D0" BorderThickness="1">
        <Grid ColumnDefinitions="Auto, 16, Auto" HorizontalAlignment="Center">
            
            <!-- Left Section: QWERTY Letters -->
            <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                <!-- Row 1 -->
                <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                    <Button Content="Q" Click="Character_Click" Width="36" Height="36" FontSize="14"/>
                    <Button Content="W" Click="Character_Click" Width="36" Height="36" FontSize="14"/>
                    <Button Content="E" Click="Character_Click" Width="36" Height="36" FontSize="14"/>
                    <Button Content="R" Click="Character_Click" Width="36" Height="36" FontSize="14"/>
                    <Button Content="T" Click="Character_Click" Width="36" Height="36" FontSize="14"/>
                    <Button Content="Y" Click="Character_Click" Width="36" Height="36" FontSize="14"/>
                    <Button Content="U" Click="Character_Click" Width="36" Height="36" FontSize="14"/>
                    <Button Content="I" Click="Character_Click" Width="36" Height="36" FontSize="14"/>
                    <Button Content="O" Click="Character_Click" Width="36" Height="36" FontSize="14"/>
                    <Button Content="P" Click="Character_Click" Width="36" Height="36" FontSize="14"/>
                </StackPanel>
                
                <!-- Row 2 -->
                <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                    <Button Content="A" Click="Character_Click" Width="36" Height="36" FontSize="14"/>
                    <Button Content="S" Click="Character_Click" Width="36" Height="36" FontSize="14"/>
                    <Button Content="D" Click="Character_Click" Width="36" Height="36" FontSize="14"/>
                    <Button Content="F" Click="Character_Click" Width="36" Height="36" FontSize="14"/>
                    <Button Content="G" Click="Character_Click" Width="36" Height="36" FontSize="14"/>
                    <Button Content="H" Click="Character_Click" Width="36" Height="36" FontSize="14"/>
                    <Button Content="J" Click="Character_Click" Width="36" Height="36" FontSize="14"/>
                    <Button Content="K" Click="Character_Click" Width="36" Height="36" FontSize="14"/>
                    <Button Content="L" Click="Character_Click" Width="36" Height="36" FontSize="14"/>
                </StackPanel>
                
                <!-- Row 3 -->
                <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                    <Button Content="Z" Click="Character_Click" Width="36" Height="36" FontSize="14"/>
                    <Button Content="X" Click="Character_Click" Width="36" Height="36" FontSize="14"/>
                    <Button Content="C" Click="Character_Click" Width="36" Height="36" FontSize="14"/>
                    <Button Content="V" Click="Character_Click" Width="36" Height="36" FontSize="14"/>
                    <Button Content="B" Click="Character_Click" Width="36" Height="36" FontSize="14"/>
                    <Button Content="N" Click="Character_Click" Width="36" Height="36" FontSize="14"/>
                    <Button Content="M" Click="Character_Click" Width="36" Height="36" FontSize="14"/>
                </StackPanel>

                <!-- Row 4: Space -->
                <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                    <Button Content="Space" Click="Space_Click" Width="220" Height="36" FontSize="14"/>
                </StackPanel>
            </StackPanel>
            
            <!-- Right Section: Numbers -->
            <Grid Grid.Column="2" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,*,*" ColumnSpacing="4" RowSpacing="4" VerticalAlignment="Center">
                <!-- Row 0: 1, 2, 3 -->
                <Button Grid.Row="0" Grid.Column="0" Content="1" Click="Number_Click" Height="36" Width="36" FontSize="14"/>
                <Button Grid.Row="0" Grid.Column="1" Content="2" Click="Number_Click" Height="36" Width="36" FontSize="14"/>
                <Button Grid.Row="0" Grid.Column="2" Content="3" Click="Number_Click" Height="36" Width="36" FontSize="14"/>
                
                <!-- Row 1: 4, 5, 6 -->
                <Button Grid.Row="1" Grid.Column="0" Content="4" Click="Number_Click" Height="36" Width="36" FontSize="14"/>
                <Button Grid.Row="1" Grid.Column="1" Content="5" Click="Number_Click" Height="36" Width="36" FontSize="14"/>
                <Button Grid.Row="1" Grid.Column="2" Content="6" Click="Number_Click" Height="36" Width="36" FontSize="14"/>
                
                <!-- Row 2: 7, 8, 9 -->
                <Button Grid.Row="2" Grid.Column="0" Content="7" Click="Number_Click" Height="36" Width="36" FontSize="14"/>
                <Button Grid.Row="2" Grid.Column="1" Content="8" Click="Number_Click" Height="36" Width="36" FontSize="14"/>
                <Button Grid.Row="2" Grid.Column="2" Content="9" Click="Number_Click" Height="36" Width="36" FontSize="14"/>
                
                <!-- Row 3: -, 0, . -->
                <Button Grid.Row="3" Grid.Column="0" Content="-" Click="Character_Click" Height="36" Width="36" FontSize="14"/>
                <Button Grid.Row="3" Grid.Column="1" Content="0" Click="Number_Click" Height="36" Width="36" FontSize="14"/>
                <Button Grid.Row="3" Grid.Column="2" Content="." Click="Character_Click" Height="36" Width="36" FontSize="14"/>

                <!-- Row 4: Del, Enter -->
                <Button Grid.Row="4" Grid.Column="0" Content="Del" Click="Del_Click" Height="36" Width="36" FontSize="12" Background="#E24A4A" Foreground="White"/>
                <Button Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Content="⏎ Enter" Click="Enter_Click" Height="36" FontSize="12" Background="#4A90E2" Foreground="White"/>
            </Grid>

        </Grid>
    </Border>
</UserControl>