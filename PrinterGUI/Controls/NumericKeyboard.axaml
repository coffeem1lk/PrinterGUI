<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PrinterGUI.Controls.NumericKeyboard">
  
  <UserControl.Styles>
      <!-- Prevent keyboard keys from stealing focus so the TextBox keeps it -->
      <Style Selector="Button">
          <Setter Property="Focusable" Value="False"/>
          <Setter Property="Background" Value="#E0E0E0"/> <!-- Slightly darker light grey for keys -->
          <Setter Property="Foreground" Value="Black"/>   <!-- Black text for keys -->
      </Style>
  </UserControl.Styles>

  <!-- Main background color changed to a very light grey -->
  <Border Background="#F5F5F5" Padding="8" CornerRadius="4" BorderBrush="#D0D0D0" BorderThickness="1">
    <!-- Updated row definitions to fit the new layout -->
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,*,*" ColumnSpacing="8" RowSpacing="8">
      
      <!-- Row 0: 1, 2, 3 -->
      <Button Grid.Row="0" Grid.Column="0" Content="1" Click="Number_Click" Height="48" Width="48" FontSize="18"/>
      <Button Grid.Row="0" Grid.Column="1" Content="2" Click="Number_Click" Height="48" Width="48" FontSize="18"/>
      <Button Grid.Row="0" Grid.Column="2" Content="3" Click="Number_Click" Height="48" Width="48" FontSize="18"/>
      
      <!-- Row 1: 4, 5, 6 -->
      <Button Grid.Row="1" Grid.Column="0" Content="4" Click="Number_Click" Height="48" Width="48" FontSize="18"/>
      <Button Grid.Row="1" Grid.Column="1" Content="5" Click="Number_Click" Height="48" Width="48" FontSize="18"/>
      <Button Grid.Row="1" Grid.Column="2" Content="6" Click="Number_Click" Height="48" Width="48" FontSize="18"/>
      
      <!-- Row 2: 7, 8, 9 -->
      <Button Grid.Row="2" Grid.Column="0" Content="7" Click="Number_Click" Height="48" Width="48" FontSize="18"/>
      <Button Grid.Row="2" Grid.Column="1" Content="8" Click="Number_Click" Height="48" Width="48" FontSize="18"/>
      <Button Grid.Row="2" Grid.Column="2" Content="9" Click="Number_Click" Height="48" Width="48" FontSize="18"/>
      
      <!-- Row 3: ., 0, Del -->
      <Button Grid.Row="3" Grid.Column="0" Content="." Click="Decimal_Click" Height="48" Width="48" FontSize="18"/>
      <Button Grid.Row="3" Grid.Column="1" Content="0" Click="Number_Click" Height="48" Width="48" FontSize="18"/>
      <!-- Del takes the spot of the old square Enter -->
      <Button Grid.Row="3" Grid.Column="2" Content="⌫" Click="Del_Click" Height="48" Width="48" FontSize="18" Background="#E24A4A" Foreground="White"/>
      
      <!-- Row 4: Wide Enter across bottom -->
      <Button Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Content="⏎ Enter" Click="Enter_Click" Height="48" FontSize="18" Background="#4A90E2" Foreground="White"/>
      
    </Grid>
  </Border>
</UserControl>