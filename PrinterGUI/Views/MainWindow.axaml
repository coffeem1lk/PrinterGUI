<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PrinterGUI.ViewModels"
        xmlns:models="using:PrinterGUI.Models"
        xmlns:controls="using:PrinterGUI.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="600"
        x:Class="PrinterGUI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="PrinterGUI"
        Width="1024" Height="600"
        MinWidth="1024" MinHeight="600">

  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="*">
    <!-- Header -->
    <Border Background="#222" Padding="12" CornerRadius="0" Grid.Row="0">
      <TextBlock Text="3D Printer" Foreground="White" FontSize="20" VerticalAlignment="Center"/>
    </Border>

    <!-- Main content -->
    <Border Grid.Row="1" Padding="8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="0.77*"/>
          <ColumnDefinition Width="1.5*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,8,0">
          <TextBlock Text="Print Type" FontWeight="Bold" Margin="4"/>
          <ListBox ItemsSource="{Binding PrintTypes}"
                   SelectedItem="{Binding SelectedPrintType}"
                   Height="360"/>
        </StackPanel>

        <StackPanel Grid.Column="1">
          <TextBlock Text="Print Parameters" FontWeight="Bold" Margin="4"/>

          <!-- ODF -->
          <Grid Margin="0,6,0,0" IsVisible="{Binding IsOdf}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1*"/>
              <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,6">
              <TextBlock Text="Layer Height (mm)" Width="132" VerticalAlignment="Center"/>
              <TextBox x:Name="LayerHeightTextBox" Text="{Binding LayerHeight}" Width="60"
                       GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>
            </StackPanel>

            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="-100,0,0,6">
              <TextBlock Text="Drying Temp (&#176;C)" Width="132" VerticalAlignment="Center"/>
              <TextBox x:Name="DryingTempTextBox" Text="{Binding DryingTemp}" Width="60"
                       GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>

              <!-- NEW: live oven temp -->
              <TextBlock Text="  Oven:" VerticalAlignment="Center" Margin="10,0,4,0"/>
              <TextBlock Text="{Binding OvenTemperatureC}" VerticalAlignment="Center" FontWeight="Bold"/>
              <TextBlock Text=" &#176;C" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,6">
              <TextBlock Text="Infill Density (%)" Width="132" VerticalAlignment="Center"/>
              <TextBox x:Name="InfillTextBox" Text="{Binding Infill}" Width="60"
                       GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="-100,0,0,6">
              <TextBlock Text="Drying Time (min)" Width="132" VerticalAlignment="Center"/>
              <TextBox x:Name="DryingTimeTextBox" Text="{Binding DryingTime}" Width="60"
                       GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>

              <!-- NEW: live extruder temp -->
              <TextBlock Text="  Extruder:" VerticalAlignment="Center" Margin="10,0,4,0"/>
              <TextBlock Text="{Binding ExtruderTemperatureC}" VerticalAlignment="Center" FontWeight="Bold"/>
              <TextBlock Text=" &#176;C" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,6">
              <TextBlock Text="Print Speed (mm/s)" Width="132" VerticalAlignment="Center"/>
              <TextBox x:Name="PrintSpeedTextBox" Text="{Binding PrintSpeed}" Width="60"
                       GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="-100,0,0,6">
              <TextBlock Text="Drying Time RT (min)" Width="132" VerticalAlignment="Center"/>
              <TextBox x:Name="DryingTimeRTTextBox" Text="{Binding DryingTimeRT}" Width="60"
                       GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,6,0,0">
              <TextBlock Text="Size (mm)" Width="132" VerticalAlignment="Center"/>
              <TextBox x:Name="OdfWidthTextBox" Text="{Binding OdfWidthMm}" Width="60"
                       GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>
              <TextBlock Text="x" Margin="8,0" VerticalAlignment="Center"/>
              <TextBox x:Name="OdfLengthTextBox" Text="{Binding OdfLengthMm}" Width="60"
                       GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>

              <TextBlock Text="#" Margin="12,0,4,0" VerticalAlignment="Center"/>
              <TextBox x:Name="OdfFilmCountTextBox" Text="{Binding OdfFilmCount}" Width="60"
                       GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>
            </StackPanel>
          </Grid>

          <!-- Gummies -->
          <Grid Margin="0,6,0,0" IsVisible="{Binding IsGummies}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1*"/>
              <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,6">
              <TextBlock Text="ml/gummy (ml)" Width="132" VerticalAlignment="Center"/>
              <TextBox x:Name="MlPerGummyTextBox" Text="{Binding GummiesMlPerGummy}" Width="60"
                       GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>
            </StackPanel>

            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="-100,0,0,6">
              <TextBlock Text="Drying Temp (&#176;C)" Width="132" VerticalAlignment="Center"/>
              <TextBox x:Name="GummiesDryingTempTextBox" Text="{Binding GummiesDryingTemp}" Width="60"
                       GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>

              <!-- NEW: live oven temp -->
              <TextBlock Text="  Oven:" VerticalAlignment="Center" Margin="10,0,4,0"/>
              <TextBlock Text="{Binding OvenTemperatureC}" VerticalAlignment="Center" FontWeight="Bold"/>
              <TextBlock Text=" &#176;C" VerticalAlignment="Center"/>
              
              <!-- NEW: live extruder temp -->
              <TextBlock Text="  Extruder:" VerticalAlignment="Center" Margin="10,0,4,0"/>
              <TextBlock Text="{Binding ExtruderTemperatureC}" VerticalAlignment="Center" FontWeight="Bold"/>
              <TextBlock Text=" &#176;C" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,6">
              <TextBlock Text="wait between gummies (s)" Width="132" VerticalAlignment="Center"/>
              <TextBox x:Name="WaitBetweenGummiesTextBox" Text="{Binding GummiesWaitBetweenSeconds}" Width="60"
                       GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="-100,0,0,6">
              <TextBlock Text="Drying Time (min)" Width="132" VerticalAlignment="Center"/>
              <TextBox x:Name="GummiesDryingTimeTextBox" Text="{Binding GummiesDryingTime}" Width="60"
                       GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,6">
              <TextBlock Text="extrusion speed (mm/min)" Width="132" VerticalAlignment="Center"/>
              <TextBox x:Name="ExtrusionSpeedTextBox" Text="{Binding GummiesExtrusionSpeed}" Width="60"
                       GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,6">
              <TextBlock Text="extrusion temp (&#176;C)" Width="132" VerticalAlignment="Center"/>
              <TextBox x:Name="GummiesExtrusionTempTextBox" Text="{Binding GummiesExtrusionTemp}" Width="60"
                       GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="-100,0,0,6">
              <TextBlock Text="Drying Time RT (min)" Width="132" VerticalAlignment="Center"/>
              <TextBox x:Name="GummiesDryingTimeRTTextBox" Text="{Binding GummiesDryingTimeRT}" Width="60"
                       GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>
            </StackPanel>

            <StackPanel Grid.Row="4" Grid.Column="0" Orientation="Vertical" Margin="0,0,8,6">
              <TextBlock Text="mm/ml" VerticalAlignment="Center" Margin="0,0,0,4"/>
              <StackPanel Orientation="Horizontal">
                <RadioButton Content="5" IsChecked="{Binding GummiesMmPerMlIs5}" Margin="0,0,12,0"/>
                <RadioButton Content="1.636" IsChecked="{Binding GummiesMmPerMlIs1636}"/>
              </StackPanel>
            </StackPanel>

            <!-- 6 blisters: 2 rows x 3 columns -->
            <Grid Grid.Row="3" Grid.Column="1" Grid.RowSpan="3" Margin="-88,0,0,0">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>

              <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                         Text="Blisters present" FontWeight="Bold" Margin="0,0,0,6"/>

              <CheckBox Grid.Row="1" Grid.Column="0" Content="B4" IsChecked="{Binding Blister4Present}" Margin="0,0,16,6"/>
              <CheckBox Grid.Row="1" Grid.Column="1" Content="B5" IsChecked="{Binding Blister5Present}" Margin="0,0,16,6"/>
              <CheckBox Grid.Row="1" Grid.Column="2" Content="B6" IsChecked="{Binding Blister6Present}" Margin="0,0,16,6"/>

              <CheckBox Grid.Row="2" Grid.Column="0" Content="B3" IsChecked="{Binding Blister3Present}" Margin="0,0,16,0"/>
              <CheckBox Grid.Row="2" Grid.Column="1" Content="B2" IsChecked="{Binding Blister2Present}" Margin="0,0,16,0"/>
              <CheckBox Grid.Row="2" Grid.Column="2" Content="B1" IsChecked="{Binding Blister1Present}" Margin="0,0,16,0"/>
            </Grid>
          </Grid>

          <!-- Global actions: 2 rows (inverted) -->
          <Grid Margin="0,12,0,0" HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="180"/>
              <ColumnDefinition Width="140"/>
              <ColumnDefinition Width="140"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 1: Set Probe + STOP -->
            <Button Grid.Row="0" Grid.Column="0"
                    Content="Set Probe Offset"
                    Click="SetProbeOffset_Click"
                    Width="160"/>

            <Button Grid.Row="0" Grid.Column="2"
                    Content="STOP"
                    Width="140"
                    Margin="8,0,0,0"
                    Background="#C62828"
                    Foreground="White"
                    Command="{Binding StopPrintCommand}"
                    IsEnabled="{Binding CanStop}"/>

            <!-- Row 2: Print Custom + Print + Axis -->
            <Button Grid.Row="1" Grid.Column="0"
                    Content="Print Custom G-code"
                    Click="PrintCustomGcode_Click"
                    Width="180"
                    Margin="0,8,0,0"
                    IsEnabled="{Binding CanPrintCustomGcode}"/>

            <Button Grid.Row="1" Grid.Column="1"
                    Content="Print"
                    Click="SendToPrinter_Click"
                    Width="140"
                    Margin="8,8,0,0"
                    IsEnabled="{Binding CanSend}"/>

            <Button Grid.Row="1" Grid.Column="2"
                    Content="Axis Control"
                    Click="AxisControl_Click"
                    Width="140"
                    Margin="8,8,0,0"/>
          </Grid>

          <TextBlock Text="{Binding Status}" Foreground="Gray" TextWrapping="Wrap" Margin="4" Height="60"/>
          <ProgressBar Minimum="0" Maximum="100" Value="{Binding Progress}" Height="14" Margin="4,6,4,0"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Overlay numeric keyboard (Microfluidics-style) -->
    <controls:NumericKeyboard x:Name="NumericKeyboard"
                              IsVisible="False"
                              Grid.RowSpan="3"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              Margin="0,0,12,0"/>

    <Border Grid.Row="2" Background="#111" Padding="8">
      <TextBlock Text="Ready" Foreground="White" HorizontalAlignment="Left" />
    </Border>
  </Grid>
</Window>
