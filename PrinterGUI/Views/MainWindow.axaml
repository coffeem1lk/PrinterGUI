<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PrinterGUI.ViewModels"
        xmlns:models="using:PrinterGUI.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="480"
        x:Class="PrinterGUI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="PrinterGUI"
        MinWidth="640" MinHeight="360">

  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="*">
    <!-- Header -->
    <Border Background="#222" Padding="12" CornerRadius="0" Grid.Row="0">
      <TextBlock Text="3D Printer" Foreground="White" FontSize="20" VerticalAlignment="Center"/>
    </Border>

    <!-- Main content wrapped in a Border to provide padding (Grid doesn't have Padding) -->
    <Border Grid.Row="1" Padding="8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="1.1*"/>
          <ColumnDefinition Width="1.5*"/>
        </Grid.ColumnDefinitions>

        <!-- Object list -->
        <StackPanel Grid.Column="0" Margin="0,0,8,0">
          <TextBlock Text="Models" FontWeight="Bold" Margin="4"/>
          <!-- Simple list without thumbnails -->
          <ListBox ItemsSource="{Binding Objects}" SelectedItem="{Binding SelectedObject}" Height="360">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:PrintObject">
                <StackPanel Orientation="Vertical" Margin="6">
                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                  <TextBlock Text="{Binding FileName}" FontSize="12" Foreground="Gray"/>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </StackPanel>

        <!-- Parameters and actions -->
        <StackPanel Grid.Column="1">
          <TextBlock Text="Print Parameters" FontWeight="Bold" Margin="4"/>

          <!-- Two-column grid for parameters: left column general, right column drying parameters -->
          <Grid Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1*"/>
              <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/> <!-- Extruder / Drying Temp -->
              <RowDefinition Height="Auto"/> <!-- Layer / Drying Time -->
              <RowDefinition Height="Auto"/> <!-- Infill / Drying Time RT -->
              <RowDefinition Height="Auto"/> <!-- Speed / (empty) -->
              <RowDefinition Height="Auto"/> <!-- Serial port (span) -->
            </Grid.RowDefinitions>

            <!-- Extruder -->
            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,6">
              <TextBlock Text="Extruder Temp (&#176;C)" Width="132" VerticalAlignment="Center"/>
              <TextBox Text="{Binding ExtruderTemp}" Width="60"/>
            </StackPanel>

            <!-- Drying Temp (moved to right column, pulled left a bit) -->
            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="-20,0,0,6">
              <TextBlock Text="Drying Temp (&#176;C)" Width="132" VerticalAlignment="Center"/>
              <TextBox Text="{Binding DryingTemp}" Width="60"/>
            </StackPanel>

            <!-- Layer height -->
            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,6">
              <TextBlock Text="Layer Height (mm)" Width="132" VerticalAlignment="Center"/>
              <TextBox Text="{Binding LayerHeight}" Width="60"/>
            </StackPanel>

            <!-- Drying time -->
            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="-20,0,0,6">
              <TextBlock Text="Drying Time (min)" Width="132" VerticalAlignment="Center"/>
              <TextBox Text="{Binding DryingTime}" Width="60"/>
            </StackPanel>

            <!-- Infill -->
            <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,6">
              <TextBlock Text="Infill Density (%)" Width="132" VerticalAlignment="Center"/>
              <TextBox Text="{Binding Infill}" Width="60"/>
            </StackPanel>

            <!-- Drying time RT -->
            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="-20,0,0,6">
              <TextBlock Text="Drying Time RT (min)" Width="132" VerticalAlignment="Center"/>
              <TextBox Text="{Binding DryingTimeRT}" Width="60"/>
            </StackPanel>

            <!-- Print speed -->
            <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,6">
              <TextBlock Text="Print Speed (mm/s)" Width="132" VerticalAlignment="Center"/>
              <TextBox Text="{Binding PrintSpeed}" Width="60"/>
            </StackPanel>

            <!-- Serial Port spans both columns and keeps original wider textbox -->
            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,6,0,0">
              <TextBlock Text="Serial Port" Width="132" VerticalAlignment="Center"/>
              <TextBox Text="{Binding SerialPortPath}" Width="160" Watermark="/dev/ttyUSB0 or /dev/ttyACM0"/>
            </StackPanel>
          </Grid>

          <!-- Generate and Send buttons -->
          <StackPanel Orientation="Horizontal" Margin="0,12,0,0" HorizontalAlignment="Left" Spacing="8">
            <Button Content="Generate G-code" Command="{Binding GenerateGcodeCommand}" Width="140" IsEnabled="{Binding CanSend}"/>
            <Button Content="Send to Printer" Click="SendToPrinter_Click" Width="140" IsEnabled="{Binding CanSend}"/>
          </StackPanel>

          <TextBlock Text="{Binding Status}" Foreground="Gray" TextWrapping="Wrap" Margin="4" Height="60"/>
          <ProgressBar Minimum="0" Maximum="100" Value="{Binding Progress}" Height="14" Margin="4,6,4,0"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Footer / credits -->
    <Border Grid.Row="2" Background="#111" Padding="8">
      <TextBlock Text="Ready" Foreground="White" HorizontalAlignment="Left" />
    </Border>
  </Grid>
</Window>
