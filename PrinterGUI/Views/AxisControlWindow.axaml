<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PrinterGUI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="500"
        x:Class="PrinterGUI.Views.AxisControlWindow"
        x:DataType="vm:AxisControlViewModel"
        Title="Axis Control"
        Width="400" Height="500"
        CanResize="False">

  <Design.DataContext>
    <vm:AxisControlViewModel/>
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*,Auto" Margin="12">
    <TextBlock Grid.Row="0" Text="Manual Axis Control" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>

    <ScrollViewer Grid.Row="1">
      <StackPanel Spacing="16">
        <!-- X Axis -->
        <StackPanel>
          <TextBlock Text="X Axis" FontWeight="SemiBold" Margin="0,0,0,4"/>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="X -10" Command="{Binding MoveXCommand}" CommandParameter="-10" Width="60"/>
            <Button Content="X -1" Command="{Binding MoveXCommand}" CommandParameter="-1" Width="60"/>
            <Button Content="X +1" Command="{Binding MoveXCommand}" CommandParameter="1" Width="60"/>
            <Button Content="X +10" Command="{Binding MoveXCommand}" CommandParameter="10" Width="60"/>
          </StackPanel>
        </StackPanel>

        <!-- Y Axis -->
        <StackPanel>
          <TextBlock Text="Y Axis" FontWeight="SemiBold" Margin="0,0,0,4"/>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Y -10" Command="{Binding MoveYCommand}" CommandParameter="-10" Width="60"/>
            <Button Content="Y -1" Command="{Binding MoveYCommand}" CommandParameter="-1" Width="60"/>
            <Button Content="Y +1" Command="{Binding MoveYCommand}" CommandParameter="1" Width="60"/>
            <Button Content="Y +10" Command="{Binding MoveYCommand}" CommandParameter="10" Width="60"/>
          </StackPanel>
        </StackPanel>

        <!-- Z Axis -->
        <StackPanel>
          <TextBlock Text="Z Axis" FontWeight="SemiBold" Margin="0,0,0,4"/>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Z -10" Command="{Binding MoveZCommand}" CommandParameter="-10" Width="60"/>
            <Button Content="Z -1" Command="{Binding MoveZCommand}" CommandParameter="-1" Width="60"/>
            <Button Content="Z +1" Command="{Binding MoveZCommand}" CommandParameter="1" Width="60"/>
            <Button Content="Z +10" Command="{Binding MoveZCommand}" CommandParameter="10" Width="60"/>
          </StackPanel>
        </StackPanel>

        <!-- E0 (Extruder 0) -->
        <StackPanel>
          <TextBlock Text="E0 (Extruder 0)" FontWeight="SemiBold" Margin="0,0,0,4"/>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="E0 -10" Command="{Binding MoveE0Command}" CommandParameter="-10" Width="60"/>
            <Button Content="E0 -1" Command="{Binding MoveE0Command}" CommandParameter="-1" Width="60"/>
            <Button Content="E0 +1" Command="{Binding MoveE0Command}" CommandParameter="1" Width="60"/>
            <Button Content="E0 +10" Command="{Binding MoveE0Command}" CommandParameter="10" Width="60"/>
          </StackPanel>
        </StackPanel>

        <!-- E1 (Extruder 1) -->
        <StackPanel>
          <TextBlock Text="E1 (Extruder 1)" FontWeight="SemiBold" Margin="0,0,0,4"/>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="E1 -10" Command="{Binding MoveE1Command}" CommandParameter="-10" Width="60"/>
            <Button Content="E1 -1" Command="{Binding MoveE1Command}" CommandParameter="-1" Width="60"/>
            <Button Content="E1 +1" Command="{Binding MoveE1Command}" CommandParameter="1" Width="60"/>
            <Button Content="E1 +10" Command="{Binding MoveE1Command}" CommandParameter="10" Width="60"/>
          </StackPanel>
        </StackPanel>

        <!-- Home All -->
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
          <Button Content="Home All (G28)" Command="{Binding HomeAllCommand}" Width="140"/>
          <Button Content="Disable Motors (M84)" Command="{Binding DisableMotorsCommand}" Width="140"/>
        </StackPanel>
      </StackPanel>
    </ScrollViewer>

    <!-- Status -->
    <StackPanel Grid.Row="2" Margin="0,12,0,0">
      <TextBlock Text="{Binding Status}" Foreground="Gray" TextWrapping="Wrap" Height="40"/>
      <Button Content="Close" Click="Close_Click" HorizontalAlignment="Right" Margin="0,8,0,0" Width="80"/>
    </StackPanel>
  </Grid>
</Window>